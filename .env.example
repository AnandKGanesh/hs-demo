# Hyperswitch Demo App - Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# BACKEND CONFIGURATION (for local development)
# ==========================================
HYPERSWITCH_SERVER_URL=https://sandbox.hyperswitch.io
HYPERSWITCH_SECRET_KEY=your_secret_key_here
HYPERSWITCH_PUBLISHABLE_KEY=your_publishable_key_here
CLIENT_URL=https://sandbox.hyperswitch.io

# Profile and Customer IDs
PROFILE_ID=your_profile_id
CUSTOMER_ID=your_customer_id

# For Relay flows (optional)
ADYEN_BASE_URL=https://your-adyen-endpoint
ADYEN_API_KEY=your_adyen_key
MERCHANT_CONNECTOR_ID=your_connector_id

# ==========================================
# FRONTEND CONFIGURATION (for Netlify deployment)
# ==========================================
# Set this to your deployed backend URL
REACT_APP_API_URL=https://your-api.onrender.com

# Example:
# REACT_APP_API_URL=https://hyperswitch-demo-api.onrender.com
